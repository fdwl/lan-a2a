[
  {
    "name": "lan_get_online_agents",
    "description": "获取局域网内所有在线的 AI 节点",
    "inputSchema": {
      "properties": {},
      "type": "object"
    }
  },
  {
    "name": "lan_open_connection",
    "description": "打开到指定 peer 的 WebSocket 连接。发送消息或文件前必须先调用此工具。",
    "inputSchema": {
      "properties": {
        "peer_id": {
          "description": "要连接的 Agent ID",
          "type": "string"
        }
      },
      "required": [
        "peer_id"
      ],
      "type": "object"
    }
  },
  {
    "name": "lan_close_connection",
    "description": "关闭到指定 peer 的 WebSocket 连接",
    "inputSchema": {
      "properties": {
        "peer_id": {
          "description": "要断开的 Agent ID",
          "type": "string"
        }
      },
      "required": [
        "peer_id"
      ],
      "type": "object"
    }
  },
  {
    "name": "lan_create_channel",
    "description": "创建通信频道并邀请 peer 加入",
    "inputSchema": {
      "properties": {
        "channel_name": {
          "description": "频道名称",
          "type": "string"
        },
        "peer_ids": {
          "description": "要邀请的 Agent ID 列表",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "channel_name",
        "peer_ids"
      ],
      "type": "object"
    }
  },
  {
    "name": "lan_leave_channel",
    "description": "退出通信频道",
    "inputSchema": {
      "properties": {
        "channel_id": {
          "description": "频道 ID",
          "type": "string"
        }
      },
      "required": [
        "channel_id"
      ],
      "type": "object"
    }
  },
  {
    "name": "lan_send_message",
    "description": "向频道发送消息。频道内所有成员的连接必须已打开。",
    "inputSchema": {
      "properties": {
        "channel_id": {
          "description": "频道 ID",
          "type": "string"
        },
        "message_body": {
          "description": "消息内容",
          "type": "string"
        }
      },
      "required": [
        "channel_id",
        "message_body"
      ],
      "type": "object"
    }
  },
  {
    "name": "lan_share_file",
    "description": "分享本地文件到频道。支持大文件（自动分块并发传输）。",
    "inputSchema": {
      "properties": {
        "channel_id": {
          "description": "频道 ID",
          "type": "string"
        },
        "file_path": {
          "description": "本地文件路径",
          "type": "string"
        }
      },
      "required": [
        "channel_id",
        "file_path"
      ],
      "type": "object"
    }
  },
  {
    "name": "lan_share_folder",
    "description": "分享整个文件夹到频道。自动检测变化，只传输修改过的文件。",
    "inputSchema": {
      "properties": {
        "channel_id": {
          "description": "频道 ID",
          "type": "string"
        },
        "folder_path": {
          "description": "本地文件夹路径",
          "type": "string"
        }
      },
      "required": [
        "channel_id",
        "folder_path"
      ],
      "type": "object"
    }
  },
  {
    "name": "lan_sync_folder",
    "description": "与远程 peer 同步本地文件夹。扫描变化，只发送 diff。",
    "inputSchema": {
      "properties": {
        "folder_path": {
          "description": "本地文件夹路径",
          "type": "string"
        },
        "peer_id": {
          "description": "远程 Agent ID",
          "type": "string"
        }
      },
      "required": [
        "folder_path",
        "peer_id"
      ],
      "type": "object"
    }
  },
  {
    "name": "lan_get_transfer_status",
    "description": "查询文件传输状态",
    "inputSchema": {
      "properties": {
        "transfer_id": {
          "description": "传输 ID",
          "type": "string"
        }
      },
      "required": [
        "transfer_id"
      ],
      "type": "object"
    }
  },
  {
    "name": "lan_list_transfers",
    "description": "列出所有活跃的文件传输",
    "inputSchema": {
      "properties": {},
      "type": "object"
    }
  }
]